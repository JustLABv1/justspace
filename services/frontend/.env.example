# JustSpace Environment Configuration
# Copy this file to .env and fill in the values

# ─── Database ───────────────────────────────────
DB_HOST=localhost
DB_USER=justspace
DB_PASSWORD=justspace
DB_NAME=justspace
DB_PORT=5432

# ─── Backend ────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
BACKEND_PORT=8080
CORS_ORIGIN=http://localhost:3000

# ─── Frontend ───────────────────────────────────
FRONTEND_PORT=3000
# The API URL as seen from the browser (for client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:8080
# The WebSocket URL as seen from the browser
NEXT_PUBLIC_WS_URL=ws://localhost:8080
